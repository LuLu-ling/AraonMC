<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base / surfaces -->
    <Color x:Key="BaseColor">#13131E</Color>
    <Color x:Key="BackgroundColor">#1B1B2A</Color>
    <Color x:Key="SurfaceColor">#252538</Color>
    <Color x:Key="SurfaceAltColor">#2C2C44</Color>
    <Color x:Key="SidebarColor">#16161F</Color>
    <Color x:Key="BorderColor">#34344C</Color>
    <Color x:Key="BorderSoftColor">#26263A</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#ECECF5</Color>
    <Color x:Key="TextSecondaryColor">#A0A0BC</Color>
    <Color x:Key="TextMutedColor">#6C6C86</Color>

    <!-- Accent (amber) -->
    <Color x:Key="AccentColor">#F59E0B</Color>
    <Color x:Key="AccentHoverColor">#FBB133</Color>
    <Color x:Key="AccentActiveColor">#D97706</Color>
    <Color x:Key="AccentForegroundColor">#1B1B2A</Color>
    <Color x:Key="AccentTintColor">#33F59E0B</Color>

    <!-- Status -->
    <Color x:Key="OnlineColor">#4ADE80</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="DangerHoverColor">#DC2626</Color>

    <!-- Notification levels -->
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="SuccessColor">#4ADE80</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>

    <!-- Corner radii (consumed by Fluent control templates + cards) -->
    <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="LargeCornerRadius">12</CornerRadius>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BaseBrush" Color="{StaticResource BaseColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderSoftBrush" Color="{StaticResource BorderSoftColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentActiveBrush" Color="{StaticResource AccentActiveColor}"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="{StaticResource AccentForegroundColor}"/>
    <SolidColorBrush x:Key="AccentTintBrush" Color="{StaticResource AccentTintColor}"/>

    <SolidColorBrush x:Key="OnlineBrush" Color="{StaticResource OnlineColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}"/>

    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>

</ResourceDictionary>
